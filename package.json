{
  "name": "ha-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bunx --bun vite",
    "build": "tsc && bunx --bun vite build",
    "test": "bunx --bun vitest run",
    "coverage": "bunx --bun vitest run --coverage",
    "format": "prettier . --write",
    "lint": "oxlint --type-aware --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "sync-types": "bun sync-types.ts",
    "preview": "bunx --bun vite preview",
    "prebuild": "bun run sync-types",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.0",
    "@testing-library/user-event": "14.6.1",
    "clsx": "2.1.1",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "lottie-react": "2.4.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.6.0",
    "react-router-dom": "7.16.0",
    "react-toastify": "11.1.0",
    "recharts": "2.15.4",
    "tailwind-merge": "3.6.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@hakit/components": "6.0.2",
    "@hakit/core": "6.0.2",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/react": "16.3.2",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/coverage-v8": "4.1.8",
    "global-jsdom": "29.0.0",
    "globals": "17.6.0",
    "happy-dom": "20.10.1",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "ts-node": "10.9.2",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "url": "0.11.4",
    "vite": "8.0.16",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": "24.16.0"
  }
